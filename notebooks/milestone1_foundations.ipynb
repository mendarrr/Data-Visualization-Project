    "\n",
    "plt.figure(figsize=(12, 6))\n",
    "sns.histplot(data=df_filtered, x='Mortality Rate (%)', hue='Disease Category', \n",
    "             bins=30, alpha=0.6, multiple='stack', palette='Set2')\n",
    "plt.title('Distribution of Mortality Rate (%)')\n",
    "plt.xlabel('Mortality Rate (%)')\n",
    "plt.ylabel('Count')\n",
    "plt.legend(title='Disease Category', bbox_to_anchor=(1.05, 1), loc='upper left')\n",
